# -----------------------------------------------------------------------------
# Admin dashboard .gitignore
# -----------------------------------------------------------------------------

# Dependencies and build outputs
node_modules/
.next/
out/
dist/
.turbo/
coverage/
*.tsbuildinfo

# Secrets and env
.env
.env.*
!.env.example

# Logs and caches
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.eslintcache

# Vercel and local tooling
.vercel/
.idea/
.DS_Store

# Generated by Flutter/Web if copied into dashboard static assets
public/app/
public/*.map
public/*.symbols
