# -----------------------------------------------------------------------------
# Rafiq admin dashboard env sample
# Server-only secrets must stay out of browser bundles.
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://qtlmumlcvcwqieexcguy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-public-anon-key

# Server runtime only. Never prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Comma-separated allowlist for Edge Functions / admin server actions.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://dashboard.rafiq.com

# Optional: used only if you later add Google Workspace SSO to the dashboard.
ADMIN_GOOGLE_CLIENT_ID=
ADMIN_GOOGLE_CLIENT_SECRET=
